{{#> base title="About" currentPath="/"}}

{{#*inline "page-head"}}

    <link rel="stylesheet" href="styleIndex.css?v={{ version }}">

{{/inline}}

{{#*inline "main-block"}}

    {{> picture
        id="logoLarge"
        title="Move Removals Logo"
        alt="The word Move stylized, looking swish"
        file="/images/move_logo"
        ext="png"
        type="png"
        width="500"
        height="500"
        nolazy=1
    }}

    {{> picture
        id="heroImg"
        title="Move Removals Van"
        alt="A smart looking van moves efficiently from left to right"
        file="/images/van"
        ext="jpg"
        type="jpeg"
        width="600"
        height="450"
        nolazy=1
    }}

    <article class="w-100 mb-auto">

        <h1 class="fc-primary">{{> tbo }} Move Removals {{> tbc }}</h1>

        <section>
            <p>Move Removals are the premier removals and courier service in Greater Manchester. If you've got something that needs shifting from one place to another, we've got the skills and the van.
            <p>Move Removals was founded in 2022, which makes it one of the most successful young removals companies in the world. Our prices are very reasonable</p>
        </section>

        <div class="points">
            {{> point
                icon="/images/points/handling"
                title="Professional Handling"
                body="You can trust Move Removals to handle your possessions with the upmost care, safety and security."
            }}
            {{> point
                icon="/images/points/delivery"
                title="Whenever, Wherever"
                body="It doesn't matter what you want moving or where it is, we can handle it."
            }}
            {{> point
                icon="/images/points/moving-truck"
                title="Fully Tracked"
                body="With end-to-end tracking you'll have peace of mind about exactly where your possessions are at every moment during your move."
            }}
            {{> point
                icon="/images/points/packages"
                title="Above and Beyond"
                body="At Move Removals we go the extra mile, sometimes literally. We don't count flights of stairs or the number of boxes, if it can be moved we'll get it."
            }}
        </div>

        <h1 class="fc-primary">{{> tbo }} The Areas We Cover {{> tbc }}</h1>

        <ul id="areaList">
            <li>{{> pin }} Oldham</li>
            <li>{{> pin }} Rochdale</li>
            <li>{{> pin }} Salford</li>
            <li>{{> pin }} Stockport</li>
            <li>{{> pin }} Tameside</li>
            <li>{{> pin }} Trafford</li>
        </ul>

    </article>

{{/inline}}

{{/base}}