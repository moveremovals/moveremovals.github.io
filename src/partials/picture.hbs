<picture {{#if id}} id="{{ id }}" {{/if}}>
    {{#unless nowebp}}
    <source srcset="{{ file }}.webp" type="image/webp">
    {{/unless}}
    <source srcset="{{ file }}.{{ ext }}" type="image/{{ type }}">
    <img 
        title="{{ title }}"
        src="{{ file }}.{{ ext }}"
        {{#unless nolazy}}
        loading="lazy"
        {{else}}
        loading="eager"
        {{/unless}}
        alt="{{ alt }}"
        width="{{ width }}"
        height="{{ height }}"
    >
</picture>